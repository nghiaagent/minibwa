Bootstrap: docker
From: debian:stable-slim

%labels
    Maintainer "lh3"
    Software "minibwa"
    Version "0.3"
    Description "Minibwa aligns short reads against a reference genome, succeeding bwa-mem."
    Software.Version "0.3"
    License "MIT"

%files
    . /src/minibwa

%post
    apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        make \
        libc-dev \
        zlib1g-dev \
        libgomp1 \
        zlib1g \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    cd /src/minibwa
    make clean && make
    cp minibwa /usr/local/bin/minibwa
    make clean

    # Remove build tools to keep the image minimal
    apt-get purge -y gcc make libc-dev zlib1g-dev
    apt-get autoremove -y

%environment
    export PATH=/usr/local/bin:$PATH

%runscript
    exec minibwa "$@"

%test
    # 1. Run version check
    minibwa version

    # 2. Run the index pipeline using the included test data
    minibwa index /src/minibwa/test/chrM-human.fa.gz /tmp/chrM-human

    # 3. Run the mapping pipeline and output to SAM
    minibwa map /tmp/chrM-human /src/minibwa/test/chrM-read_1.fa.gz /src/minibwa/test/chrM-read_2.fa.gz > /tmp/aln.sam
